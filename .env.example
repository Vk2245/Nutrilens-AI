# =============================================================================
# NutriLens AI — Environment Configuration
# Copy this file to .env and fill in your values
# ALL services below are FREE — no GCP billing required!
# =============================================================================

# --- Google Gemini AI (FREE) ---
# Get your API key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- Google Service Account (FREE from Firebase Console) ---
GOOGLE_APPLICATION_CREDENTIALS=firebase-credentials.json

# --- Google Sheets API (FREE, no billing) ---
GOOGLE_SHEETS_ID=your_sheet_id_here

# --- Firebase (Spark Plan — FREE, no billing) ---
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=nutrilensai.firebaseapp.com
FIREBASE_PROJECT_ID=nutrilensai
FIREBASE_DATABASE_URL=https://nutrilensai-default-rtdb.firebaseio.com
FIREBASE_STORAGE_BUCKET=nutrilensai.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id
FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# --- Google Maps Places API (FREE tier) ---
GOOGLE_MAPS_API_KEY=your_maps_api_key

# --- YouTube Data API v3 (FREE tier) ---
YOUTUBE_API_KEY=your_youtube_api_key

# --- Google reCAPTCHA v3 (FREE) ---
RECAPTCHA_SITE_KEY=your_recaptcha_site_key
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key

# --- Application Settings ---
APP_SECRET_KEY=change-this-in-production
APP_ENV=development
CORS_ORIGINS=http://localhost:8000,http://localhost:3000
PORT=8000
DEMO_MODE=true
